[project]
name = "marketing-analyzer"
version = "1.0.0"
description = "Marketing performance analyzer with Claude AI insights"
requires-python = ">=3.12"
dependencies = [
    "anthropic>=0.40.0",
]

[project.scripts]
analyze = "marketing_analyzer:main"

[tool.pytest.ini_options]
asyncio_mode = "auto"

[dependency-groups]
dev = [
    "pytest>=8.0.0",
    "pytest-asyncio>=0.24.0",
]
